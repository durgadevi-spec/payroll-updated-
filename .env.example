# Copy this file to .env and update with your actual database connection strings.

PAYROLL_DATABASE_URL=postgresql://postgres.<username>:<password>@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres
LMS_DATABASE_URL=postgresql://postgres.<username>:<password>@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres
TIMESHEET_DATABASE_URL=postgresql://postgres.<username>:<password>@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?sslmode=require

# If you are also using a Supabase project for frontend access, set these.
VITE_SUPABASE_URL=https://<your-supabase-project>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Resend email API configuration for payslip delivery
RESEND_API_KEY=re_<your-resend-api-key>
EMAIL_FROM=admin@company.com
